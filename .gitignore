# -------------------------------

target/
*.log
*.class
*.jar
*.war
*.ear

# Maven

.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# Gradle (ileride lazım olabilir)

.gradle/
build/

# -------------------------------

# 🟨 IntelliJ IDEA

# -------------------------------

.idea/
*.iws
*.iml
*.ipr
out/

# -------------------------------

# 🟪 VS Code

# -------------------------------

.vscode/

# -------------------------------

# 🟩 NetBeans

# -------------------------------

/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# -------------------------------

# 🟥 OS Files

# -------------------------------

.DS_Store
Thumbs.db
desktop.ini

# -------------------------------

# 🟫 Logs

# -------------------------------

logs/
*.log

# -------------------------------

# 🟧 Environment & Secrets

# -------------------------------

.env
.env.*
*.env

# -------------------------------

# 🐳 Docker

# -------------------------------

docker-data/
*.pid

# -------------------------------

# 📦 Node / React (frontend için)

# -------------------------------

node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------

# 🧪 Test / Coverage

# -------------------------------

coverage/
*.lcov

# -------------------------------
# 🗂 Uploads / Static Files
# -------------------------------

uploads/
cvs/

# sadece upload edilen dosyaları ignore et
uploads/**/*.pdf
uploads/**/*.png
uploads/**/*.jpg
uploads/**/*.jpeg

# -------------------------------

# 🔐 Sensitive Files

# -------------------------------

*.key
*.pem
*.crt

# -------------------------------

# 🧩 Misc

# -------------------------------

*.swp
*.swo
*.tmp
*.bak

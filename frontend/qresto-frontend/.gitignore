# ===============================
# 🚀 QResto Frontend .gitignore
# ===============================

# -------------------------------
# 📦 Node
# -------------------------------
node_modules/
dist/
dist-ssr/
.vite/

# -------------------------------
# 📝 Logs
# -------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------
# 🧪 Coverage
# -------------------------------
coverage/
*.lcov

# -------------------------------
# 🧠 Env (ÇOK ÖNEMLİ)
# -------------------------------
.env
.env.*
*.local

# örnek config tutulabilir
!.env.example

# -------------------------------
# 🧩 Editor / IDE
# -------------------------------
.vscode/*
!.vscode/extensions.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# -------------------------------
# 🟥 OS Files
# -------------------------------
.DS_Store
Thumbs.db

# -------------------------------
# 🖼️ Upload / Temp Files
# -------------------------------
uploads/*
!uploads/.gitkeep

# -------------------------------
# 🧾 Build Artifacts
# -------------------------------
*.tsbuildinfo

# -------------------------------
# 🔐 Secrets / Keys
# -------------------------------
*.pem
*.key
*.crt